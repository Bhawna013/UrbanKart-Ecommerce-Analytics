# DATABASE CREATION


CREATE DATABASE urbankart;

USE urbankart;

-- =====================================================
-- Categories
-- =====================================================

CREATE TABLE categories (
    category_id INT PRIMARY KEY,
    category_name VARCHAR(100),
    department VARCHAR(100),
    is_active VARCHAR(10),
    created_date DATE
);

UPDATE categories
SET is_active =
CASE
    WHEN is_active = 'TRUE' THEN '1'
    WHEN is_active = 'FALSE' THEN '0'
END;


-- =====================================================
-- Suppliers
-- =====================================================

CREATE TABLE suppliers (
    supplier_id INT PRIMARY KEY,
    supplier_name VARCHAR(150) NOT NULL,
    city VARCHAR(100),
    state VARCHAR(100),
    lead_time_days INT,
    quality_rating DECIMAL(3,2),
    contact_person VARCHAR(100),
    email VARCHAR(150),
    phone VARCHAR(20),
    is_active VARCHAR(10)
);

UPDATE suppliers
SET is_active =
CASE
    WHEN is_active = 'TRUE' THEN '1'
    WHEN is_active = 'FALSE' THEN '0'
END;

-- =====================================================
-- Warehouses
-- =====================================================

CREATE TABLE warehouses (
    warehouse_id INT PRIMARY KEY,
    warehouse_name VARCHAR(150) NOT NULL,
    city VARCHAR(100),
    state VARCHAR(100),
    capacity INT,
    manager_name VARCHAR(100),
    opening_date DATE,
    is_active VARCHAR(10)
);

UPDATE warehouses
SET is_active =
CASE
    WHEN is_active = 'TRUE' THEN '1'
    WHEN is_active = 'FALSE' THEN '0'
END;

-- =====================================================
-- Couriers
-- =====================================================

CREATE TABLE couriers (
    courier_id INT PRIMARY KEY,
    courier_name VARCHAR(100) NOT NULL,
    service_type VARCHAR(50),
    headquarters_city VARCHAR(100),
    average_rating DECIMAL(3,2),
    is_active VARCHAR(10)
);

UPDATE couriers
SET is_active =
CASE
    WHEN is_active = 'TRUE' THEN '1'
    WHEN is_active = 'FALSE' THEN '0'
END;

-- =====================================================
-- Customers
-- =====================================================

CREATE TABLE customers (
    customer_id INT PRIMARY KEY,
    first_name VARCHAR(50) NOT NULL,
    last_name VARCHAR(50) NOT NULL,
    gender VARCHAR(10),
    age INT,
    email VARCHAR(150) UNIQUE,
    phone VARCHAR(20),
    city VARCHAR(100),
    state VARCHAR(100),
	pincode VARCHAR(10),
    signup_date DATE,
    acquisition_channel VARCHAR(50),
    loyalty_tier VARCHAR(20),
    is_active VARCHAR(10)
);



UPDATE customers
SET is_active =
CASE
    WHEN is_active = 'TRUE' THEN '1'
    WHEN is_active = 'FALSE' THEN '0'
END;


-- =====================================================
-- Marketing Campaigns
-- =====================================================

CREATE TABLE marketing_campaigns (
    campaign_id INT PRIMARY KEY,
    campaign_name VARCHAR(150) NOT NULL,
    channel VARCHAR(50),
    objective VARCHAR(100),
    budget DECIMAL(12,2),
    start_date DATE,
    end_date DATE,
    status VARCHAR(30)
);

-- =====================================================
-- Date Dimension
-- =====================================================

CREATE TABLE date_dim (
    date_id INT PRIMARY KEY,
    full_date DATE,
    day INT,
    day_name VARCHAR(15),
    week_of_year INT,
    month INT,
    month_name VARCHAR(15),
    quarter VARCHAR(5),
    year INT,
    season VARCHAR(20),
    festival VARCHAR(50),
    is_weekend VARCHAR(10),
    is_month_start VARCHAR(10),
    is_month_end VARCHAR(10),
    is_quarter_start VARCHAR(10),
    is_quarter_end VARCHAR(10),
    is_year_start VARCHAR(10),
    is_year_end VARCHAR(10)
);
		

-- =====================================================
-- Products
-- =====================================================

CREATE TABLE products (
    product_id INT PRIMARY KEY,
    product_name VARCHAR(200) NOT NULL,
    brand VARCHAR(100),
    category_id INT,
    supplier_id INT,
    cost_price DECIMAL(10,2),
    selling_price DECIMAL(10,2),
    weight_kg DECIMAL(6,2),
    launch_date DATE,
    is_active VARCHAR(10)
);


UPDATE products
SET is_active =
CASE
    WHEN is_active = 'TRUE' THEN '1'
    WHEN is_active = 'FALSE' THEN '0'
END;

-- =====================================================
-- Inventory
-- =====================================================

CREATE TABLE inventory (
    inventory_id INT PRIMARY KEY,
    product_id INT NOT NULL,
    warehouse_id INT NOT NULL,
    stock_quantity INT NOT NULL,
    reorder_level INT NOT NULL,
    reorder_quantity INT NOT NULL,
    last_restock_date DATE,
    inventory_status VARCHAR(30)
);



-- =====================================================
-- Orders
-- =====================================================
CREATE TABLE orders (
    order_id INT PRIMARY KEY,
    customer_id INT NOT NULL,
    order_date DATE,
    campaign_id VARCHAR(20),
    payment_method VARCHAR(50),
    order_status VARCHAR(30),
    subtotal DECIMAL(12,2),
    discount_amount DECIMAL(12,2),
    tax_amount DECIMAL(12,2),
    shipping_fee DECIMAL(10,2),
    total_amount DECIMAL(12,2)
);


UPDATE orders
SET campaign_id = NULL
WHERE TRIM(campaign_id) IN ('NULL', 'Null', 'null', '');


ALTER TABLE orders
MODIFY campaign_id INT NULL; 


-- =====================================================
-- Order Items
-- =====================================================

CREATE TABLE order_items (
    order_item_id INT PRIMARY KEY,
    order_id INT NOT NULL,
    product_id INT NOT NULL,
    quantity INT NOT NULL,
    unit_price DECIMAL(12,2) NOT NULL,
    gross_amount DECIMAL(12,2) NOT NULL,
    discount_percent DECIMAL(5,2) NOT NULL,
    discount_amount DECIMAL(12,2) NOT NULL,
    line_total DECIMAL(12,2) NOT NULL
);



-- =====================================================
-- Payments
-- =====================================================
SET sql_mode='';
DROP TABLE payments;

CREATE TABLE payments (
    payment_id INT PRIMARY KEY,
    order_id INT,
    payment_method VARCHAR(50),
    payment_date DATE NULL,
    payment_status VARCHAR(30),
    amount_paid DECIMAL(10,2)
);


-- =====================================================
-- Shipping
-- =====================================================

CREATE TABLE shipping (
    shipping_id INT PRIMARY KEY,
    order_id INT,
    warehouse_id INT,
    courier_id INT,
    dispatch_date DATE NULL,
    estimated_delivery_date DATE NULL,
    actual_delivery_date DATE NULL,
    shipping_status VARCHAR(50)
);



-- =====================================================
-- Returns
-- =====================================================

CREATE TABLE returns (
    return_id INT PRIMARY KEY,
    order_id INT NOT NULL,
    return_date DATE,
    return_reason VARCHAR(100),
    refund_amount DECIMAL(12,2),
    refund_status VARCHAR(30)
);


-- =====================================================
-- Reviews
-- =====================================================
CREATE TABLE reviews (
    review_id INT PRIMARY KEY,
    order_id INT NOT NULL,
    rating INT,
    review_date DATE,
    review_comment VARCHAR(500)
);




