# KPI 14: Repeat Customers 

SELECT
COUNT(*) AS repeat_customers
FROM
(SELECT customer_id
FROM orders
GROUP BY customer_id
HAVING COUNT(*)>1 
)t;



# KPI 15: REPEAT CUSTOMER RATE 

SELECT 
	ROUND(100*COUNT(*)/(SELECT COUNT(*) FROM CUSTOMERS),2) AS repeat_customer_rate
FROM (
	select customer_id 
    FROM orders
    group by customer_id
    having count(*)> 1
    )t;
    


# SECTION 5: OPERATIONAL KPIs

# KPI 16: RETURN RATE 

select round(100*sum(order_status='Returned')/count(*),2) as return_rate
from orders;


# KPI 17: CANCELLATION RATE 

Select ROUND(100*SUM(order_status = 'Cancelled')/count(*),2) as cancellation_rate
from orders;


#KPI 17: LOST SHIPMENT RATE 

select ROUND(100*sum(order_status = 'Lost')/
	count(*),2) as lost_order_status
