# KPI 19: INVENTORY HEALTH

select inventory_status, 
	count(*) as products
from inventory
group by inventory_status;


# KPI 20: AVEREAGE STOCK BY CATEGORY

select 
	c.category_name,
    ROUND(AVG(i.stock_quantity),2) AS average_stock
FROM inventory i
join products p
on i.product_id = p.product_id
join categories c
on p.category_id = c.category_id
group by c.category_name
order by average_stock desc;




## ADVANCED BUSINESS ANALYSIS

# QUERY 1 : TOP 10 CUSTOMERS BY LIFETIME VALUE (LTV)
	# business qs? which customers generate the most revenue?

select
	c.customer_id,
    c.`name`,
    count(o.order_id) as total_orders,
    round(sum(o.total_amount),2) as lifetime_value
from customers c
join orders o
on c.customer_id = o.customer_id
where o.order_status = 'Delivered'
group by c.customer_id, c.`name`
order by lifetime_value desc
limit 10;


# QUERY 2 - CUSTOMER PURCHASE FREQUENCY

SELECT 
	customer_id,
    count(order_id) as total_orders,
    round(avg(total_amount),2) as avg_order_value
from orders
where order_status = 'Delivered'
group by customer_id
order by total_orders desc;


# QUERY 3 - TOP 10 CITIES BY REVENUE

SELECT
	c.city,
    ROUND(SUM(o.total_amount),2) as revenue
FROM customers c
join orders o
on c.customer_id = o.customer_id
where o.order_status = 'Delivered'
group by c.city
order by revenue desc
limit 10;


# QUERY 4 - REVENUE BY STATE

SELECT
    c.state,
    ROUND(SUM(o.total_amount),2) AS revenue
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
WHERE o.order_status='Delivered'
GROUP BY c.state
ORDER BY revenue DESC;


# QUERY 5 - ACQUISITTION CHANNEL PERFORMANCE

SELECT
    c.acquisition_channel,
    COUNT(DISTINCT c.customer_id) AS customers,
    COUNT(o.order_id) AS orders,
    ROUND(SUM(o.total_amount),2) AS revenue
FROM customers c
LEFT JOIN orders o
ON c.customer_id=o.customer_id
AND o.order_status='Delivered'
GROUP BY c.acquisition_channel
ORDER BY revenue DESC;



# QUERY 6 - LOYALTY TIER PERFORMANCE

SELECT
	loyalty_tier,
    COUNT(DISTINCT c.customer_id) as customers,
    ROUND(SUM(o.total_amount),2) as revenue,
    ROUND(AVG(o.total_amount),2) as avg_order_value
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
AND o.order_status = 'Delivered'
GROUP BY loyalty_tier
ORDER BY revenue desc;


# QUERY 7 - PRODUCT PROFITABILITY

SELECT
	p.product_name,
    ROUND(SUM(oi.line_total),2) as revenue,
    ROUND((SUM(oi.unit_price - p.cost_price)* oi.quantity),2) AS estimated_profit
FROM order_items oi
JOIN products p
ON oi.product_id = p.product_id
GROUP BY p.product_name
ORDER BY estimated_profit DESC
LIMIT 15;


# QUERY 8 - HIGHEST MARGIN PRODUCTS

SELECT 
	product_name,
    cost_price,
    selling_price,
    ROUND(
		((selling_price - cost_price)/selling_price)*100, 2)
			AS margin_percent
FROM products
ORDER BY margin_percent DESC;


# QUERY 9 - INVENTORY AT RISK
		# Products that need restocking
        
SELECT 
	inventory_id,
    product_id,
    stock_quantity,
    reorder_level 
FROM inventory
WHERE stock_quantity <= reorder_level;


# QUERY 10 - RETURN ANALYSIS BY CATEGORY

SELECT
	cat.category_name,
	COUNT(r.return_id) AS total_returns
FROM returns r

JOIN orders o
ON r.order_id=o.order_id

JOIN order_items oi
ON o.order_id=oi.order_id

JOIN products p
ON oi.product_id=p.product_id

JOIN categories cat
ON p.category_id=cat.category_id

GROUP BY cat.category_name
ORDER BY total_returns DESC;


# QUERY 11 - AVERAGE RATING BY CATEGORY

SELECT
	cat.category_name,
	ROUND(AVG(rv.rating),2) AS average_rating
FROM reviews rv

JOIN orders o
ON rv.order_id=o.order_id

JOIN order_items oi
ON o.order_id=oi.order_id

JOIN products p
ON oi.product_id=p.product_id

JOIN categories cat
ON p.category_id=cat.category_id

GROUP BY cat.category_name
ORDER BY average_rating DESC;



# QUERY 12 - MONTHLY REVENUE GROWTH (WINDOW FUNCTION)

WITH monthly_sales AS (
	SELECT DATE_FORMAT(order_date, '%Y-%m') AS month,
    SUM(total_amount) AS revenue
FROM orders
WHERE order_status = 'Delivered'
GROUP BY DATE_FORMAT(order_date, '%Y-%m')
)
SELECT month, ROUND(revenue,2) as revenue,
	ROUND(revenue - LAG(revenue) OVER (ORDER BY month),2)
		AS revenue_change
FROM monthly_sales;



# QUERY 13 - RANK PRODUCTS BY REVENUE

Select 
	p.product_name,
    SUM(oi.line_total) AS revenue,
    RANK() OVER (ORDER BY SUM(oi.line_total) DESC) AS product_rank
FROM order_items oi
JOIN products p
ON oi.product_id = p.product_id
GROUP BY p.product_name;


# QUERY 14 - TOP PRODUCT IN EACH CATEGORY (WINDOW FUNCTION)

WITH product_sales AS 
	( SELECT c.category_name, p.product_name, 
		SUM(oi.line_total) revenue
	 FROM order_items oi
     
     JOIN products p
     ON oi.product_id = p.product_id
     
     JOIN categories c
     ON p.category_id = c.category_id
     
     GROUP BY c.category_name, p.product_name)
     
SELECT * FROM (
	SELECT *, 
    ROW_NUMBER() OVER (PARTITION BY category_name ORDER BY revenue DESC) rn
	FROM product_sales ) x
WHERE rn =1;
		
    

# QUERY 15 - CSUTOMER RFM FOUNDATION
		# Customer segmentation model.
        
SELECT
	customer_id,
    MAX(order_date) AS last_purchase_date,
    COUNT(order_id) AS frequency,
    ROUND(SUM(total_amount),2) AS monetary
FROM orders
WHERE order_status = 'Delivered'
GROUP BY customer_id;



#VIEWS

VIEW 1 - CUSTOMER SALES SUMMARY
	# Business Purpose - every customer's performance in one table
    
CREATE VIEW vw_customer_sales AS
SELECT 
	c.customer_id,
    c.`name`,
    c.city,
    c.state,
    c.loyalty_tier,
    COUNT(o.order_id) as total_orders,
    ROUND(SUM(o.total_amount),2) as total_spent,
    ROUND(AVG(o.total_amount),2) as AOV
FROM customers c
LEFT JOIN orders o
	ON c.customer_id = o.customer_id
AND o.order_status = 'Delivered'
GROUP BY 
	c.customer_id,
    c.`name`,
    c.city,
    c.state,
    c.loyalty_tier;
    
    
SELECT * 
FROM vw_customer_sales;



# VIEW 2 - PRODUCT PERFORMANCE

CREATE VIEW vw_product_performance AS 
SELECT 
	p.product_id,
    p.product_name,
    c.category_name,
    p.brand,
    SUM(oi.quantity) AS units_sold,
    ROUND(SUM(oi.line_total),2) as revenue,
    ROUND(
		SUM((oi.unit_price - p.cost_price)*oi.quantity),2) AS estimated_profit
FROM products p
JOIN categories c
	ON p.category_id = c.category_id
LEFT JOIN order_items oi
	ON p.product_id = oi.product_id
GROUP BY
	p.product_id,
    p.product_name,
    c.category_name,
    p.brand;


SELECT *
FROM vw_product_performance;
    


# VIEW 3 - CATEGORY PERFORMANCE

CREATE VIEW vw_category_performance AS
SELECT 
	c.category_name,
    COUNT(DISTINCT p.product_id) AS total_products,
    SUM(oi.quantity) AS units_sold,
    ROUND(SUM(oi.line_total),2) as revenue
FROM categories c
LEFT JOIN products p
	ON c.category_id=p.category_id
LEFT JOIN order_items oi
	ON p.product_id=oi.product_id
GROUP BY c.category_name;
    
    
SELECT *
FROM vw_category_performance;    





# VIEW 4 - MONTHLY SALES

CREATE VIEW vw_monthly_sales AS
SELECT
	YEAR(order_date) AS year,
    MONTH(order_date) AS month,
    COUNT(order_id) AS total_orders,
    ROUND(SUM(total_amount),2) AS revenue,
    ROUND(AVG(total_amount),2) AS AOV
from orders
WHERE order_status = 'Delivered'
GROUP BY YEAR(order_date), MONTH(order_date);

SELECT *
FROM vw_monthly_sales; 


# VIEW 5 - INVENTORY DASHBOARD

CREATE VIEW vw_inventory_status AS
SELECT
	i.inventory_id,
	p.product_name,
	c.category_name,
	w.warehouse_name,
	i.stock_quantity,
	i.reorder_level,
	i.inventory_status
FROM inventory i
JOIN products p
	ON i.product_id=p.product_id
JOIN categories c
	ON p.category_id=c.category_id
JOIN warehouses w
	ON i.warehouse_id=w.warehouse_id;


SELECT *
FROM vw_inventory_status; 


    
# VIEW 6 - RETURNS DASHBOARD

CREATE VIEW vw_return_analysis AS
SELECT
	r.return_id,
	r.return_date,
	r.return_reason,
	r.refund_amount,
	o.order_id,
	c.`name`,
	p.product_name,
	cat.category_name
FROM returns r
JOIN orders o
	ON r.order_id=o.order_id
JOIN customers c
	ON o.customer_id=c.customer_id
JOIN order_items oi
	ON o.order_id=oi.order_id
JOIN products p
	ON oi.product_id=p.product_id
JOIN categories cat
	ON p.category_id=cat.category_id;
    

SELECT *
FROM vw_return_analysis; 


# VIEW 7 - REVIEW DASHBOARD

CREATE VIEW vw_review_summary AS
SELECT
rv.review_id,
rv.rating,
rv.review_date,
p.product_name,
cat.category_name,
c.`name`
FROM reviews rv
JOIN orders o
	ON rv.order_id=o.order_id
JOIN customers c
	ON o.customer_id=c.customer_id
JOIN order_items oi
	ON o.order_id=oi.order_id
JOIN products p
	ON oi.product_id=p.product_id
JOIN categories cat
	ON p.category_id=cat.category_id;

SELECT *
FROM vw_review_summary;



# VIEW 8 - MARKETING PERFORMANCE

CREATE VIEW vw_marketing_performance AS
SELECT
    mc.campaign_id,
    mc.campaign_name,
    COUNT(o.order_id) AS total_orders,
    ROUND(COALESCE(SUM(o.total_amount),0),2) AS revenue,
    ROUND(COALESCE(AVG(o.total_amount),0),2) AS average_order_value
FROM marketing_campaigns mc
LEFT JOIN orders o
    ON mc.campaign_id = o.campaign_id
   AND o.order_status = 'Delivered'
GROUP BY
    mc.campaign_id,
    mc.campaign_name;


SELECT *
FROM vw_marketing_performance;



# VIEW 9 - SHIPPING DASHBOARD

CREATE VIEW vw_shipping_summary AS
SELECT
	s.shipping_id,
	o.order_id,
	c.`name`,
	co.courier_name,
	w.warehouse_name,
	s.dispatch_date,
	s.estimated_delivery_date,
	s.actual_delivery_date,
	s.shipping_status
FROM shipping s
JOIN orders o
	ON s.order_id=o.order_id
JOIN customers c
	ON o.customer_id=c.customer_id
JOIN couriers co
	ON s.courier_id=co.courier_id
JOIN warehouses w
	ON s.warehouse_id=w.warehouse_id;
    
SELECT *
FROM vw_review_summary;
