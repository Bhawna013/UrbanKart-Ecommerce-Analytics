## BUSINESS KPIs

02. BUSINESS KPIs

# SECTION 1: EXECUTIVE KPIs

## KPI 1 : TOTAL REVENUE
			# Business Qs: How much revenue have we generated?
			
select 
	round(sum(total_amount),2) AS total_revenue
from orders
where order_status = 'Delivered';


## KPI 2 : TOTAL ORDERS 
	
    select count(*) as total_orders
    from orders;
    
# KPI 3 : DELIVERED ORDERS 

	select count(*) as deleivered_orders
    from orders
    where order_status = 'Delivered';
    

# KPI 4 : TOTAL CUSTOMERS 

	select count(*) as total_customers
    from customers;

# KPI 5 : AVERAGE ORDER VALUE (AOV)
		# one of the most important ecommerce KPIs.
        
	select 
		round(avg(total_amount),2) as average_order_value
	from orders
    where order_status = 'Delivered';
    

# KPI 6 : TOTAL PRODUCTS SOLD 

	select sum(quantity) as products_sold
    from order_items;
    


# SECTION 2: SALES ANALYSIS

# KPI 7 : MONTHLY REVENUE TREND

	select 
		year(order_date) as year,
        month(order_date) as month,
        round(sum(total_amount),2) as revenue
	from orders
	where order_status = 'Delivered'
    group by year(order_date), month(order_date)
    order by year, month;
        
        
# KPI 8 : MONTHLY ORDER TREND

select 
	YEAR(order_date),
    Month(order_date),
    count(*) as total_orders
from orders
group by year(order_date), month(order_date)
order by year(order_date), month(order_date);


# KPI 9 : REVENUE BY PAYMENT METHOD

	select
		payment_method, 
        ROUND(SUM(total_amount),2) as revenue
	from orders
    where order_status = 'Delivered'
    group by payment_method
    order by revenue desc;
    

# SECTION 3: PRODUCT ANALYSIS

# KPI 10: TOP 10 PRODUCTS BY REVENUE

	select 
		p.product_name,
        Round(Sum(oi.line_total),2) as revenue
	from order_items oi
    join products p
    on oi.product_id = p.product_id
    group by p.product_name
    order by revenue desc
    limit 10;


# KPI 11: TOP CATEGORIES BY REVENUE

	select 
		c.category_name,
        ROUND(SUM(oi.line_total),2) as revenue
	from order_items oi
    join products p
    on oi.product_id = p.product_id
    join categories c
    on p.category_id = c.category_id
    group by c.category_name
    order by revenue desc;
    
    
# KPI 12 : BEST SELLING PRODUCTS

select
	p.product_name,
    sum(oi.quantity) as units_sold
from order_items oi
join products p
on oi.product_id = p.product_id
group by p.product_name
order by units_sold desc
limit 10;


# SECTION 4: CUSTOMER ANALYSIS

# KPI 13: TOP 10 CUSTOMERS BY REVENUE

ALTER TABLE customers
add `name` varchar(100);
SET SQL_SAFE_UPDATES = 0;
update customers
SET `name` = CONCAT(first_name, ' ', last_name);



select 
	c.`name`,
    ROUND(SUM(o.total_amount),2) as total_spent
from orders o
join customers c
on o.customer_id = c.customer_id
where o.order_status = 'Delivered'
group by c.`name`
order by total_spent desc
